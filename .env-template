# git clone 後に `cp .env-template .env` してから利用
# docker-compose.yml と packages/server が参照

# Postgres
POSTGRES_DB=bluff
POSTGRES_USER=bluff
POSTGRES_PASSWORD=bluff

# Server(ホスト側の公開ポート / コンテナ内の待受ポート兼用)
SERVER_PORT=4000

# Client(Vite dev server のホスト側公開ポート、HMR 都合で 5173 推奨)
CLIENT_PORT=5173

# Client のビルド時に埋め込まれるサーバー URL
# ブラウザから到達可能な URL を指定(Docker 内部名 `server:4000` は不可)
# 同 LAN の他デバイス(スマホ等)でテストする場合は、ホスト機の LAN IP を指定:
#   `ipconfig getifaddr en0` などで確認 → 値を書き換え後 `docker compose restart client`
# VITE_SERVER_URL=http://localhost:4000
VITE_SERVER_URL=http://192.168.x.x:4000

# Server が参照する DB 接続文字列
# docker-compose 経由: ホスト名 `postgres`
# ローカル実行: ホスト名 `localhost`
DATABASE_URL=postgres://bluff:bluff@postgres:5432/bluff
